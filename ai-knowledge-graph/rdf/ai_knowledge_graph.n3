ai:AI_Knowledge_Graph a owl:Ontology ;
    rdfs:label "人工智能核心概念知识图谱本体"@zh ;
    rdfs:comment "定义人工智能领域的核心概念、实体和关系"@zh .

ai:appliedIn a owl:ObjectProperty ;
    rdfs:label "应用于"@zh ;
    rdfs:comment "应用于某场景"@zh ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ai:Model ai:Algorithm ai:Technique ) ] ;
    rdfs:range ai:Application .

ai:basedon a owl:ObjectProperty ;
    rdfs:label "基于"@zh ;
    rdfs:comment "某技术基于另一技术发展而来"@zh ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ai:Model ai:Algorithm ai:Technique ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( ai:Model ai:Algorithm ai:Technique ) ] .

ai:belongsTo a owl:ObjectProperty ;
    rdfs:label "属于"@zh ;
    rdfs:comment "某实体属于某领域或类别"@zh ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ai:Algorithm ai:Model ai:Technique ai:Application ) ] ;
    rdfs:range ai:AI_Field .

ai:description a owl:DatatypeProperty ;
    rdfs:label "描述"@zh ;
    rdfs:range xsd:string .

ai:developedBy a owl:ObjectProperty ;
    rdfs:label "开发者"@zh ;
    rdfs:comment "由某人或组织开发"@zh ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ai:Model ai:Algorithm ai:Tool ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( ai:Person ai:Organization ) ] .

ai:field a owl:DatatypeProperty ;
    rdfs:label "研究领域"@zh ;
    rdfs:domain ai:Person ;
    rdfs:range xsd:string .

ai:founded a owl:DatatypeProperty ;
    rdfs:label "成立年份"@zh ;
    rdfs:domain ai:Organization ;
    rdfs:range xsd:gYear .

ai:isPartOf a owl:ObjectProperty ;
    rdfs:label "是...的一部分"@zh ;
    rdfs:comment "某概念是更大概念的组成部分"@zh ;
    owl:propertyType owl:TransitiveProperty .

ai:name a owl:DatatypeProperty ;
    rdfs:label "名称"@zh ;
    rdfs:range xsd:string .

ai:nationality a owl:DatatypeProperty ;
    rdfs:label "国籍"@zh ;
    rdfs:domain ai:Person ;
    rdfs:range xsd:string .

ai:parameters a owl:DatatypeProperty ;
    rdfs:label "参数量"@zh ;
    rdfs:range xsd:string .

ai:proposes a owl:ObjectProperty ;
    rdfs:label "提出"@zh ;
    rdfs:comment "提出某概念或方法"@zh ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ai:Person ai:Organization ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( ai:Concept ai:Algorithm ai:Model ) ] .

ai:relatedTo a owl:ObjectProperty ;
    rdfs:label "相关"@zh ;
    rdfs:comment "两个实体相关"@zh ;
    owl:propertyType owl:SymmetricProperty .

ai:usesAlgorithm a owl:ObjectProperty ;
    rdfs:label "使用算法"@zh ;
    rdfs:comment "模型或应用使用某算法"@zh ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ai:Model ai:Application ) ] ;
    rdfs:range ai:Algorithm .

ai:usesTool a owl:ObjectProperty ;
    rdfs:label "使用工具"@zh ;
    rdfs:comment "使用某工具实现"@zh ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ai:Model ai:Application ) ] ;
    rdfs:range ai:Tool .

ai:worksAt a owl:ObjectProperty ;
    rdfs:label "工作于"@zh ;
    rdfs:comment "某人在某组织工作"@zh ;
    rdfs:domain ai:Person ;
    rdfs:range ai:Organization .

ai:year a owl:DatatypeProperty ;
    rdfs:label "年份"@zh ;
    rdfs:range xsd:gYear .

